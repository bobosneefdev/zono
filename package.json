{
    "name": "@bobosneefdev/zono",
    "version": "7.0.0",
    "packageManager": "bun@1.3.5",
    "description": "Easily create type-safe APIs, clients, and servers with Zod and Hono.",
    "homepage": "https://github.com/bobosneefdev/zono#readme",
	"exports": {
		"./contract": {
			"types": "./dist/contract.d.ts",
			"import": "./dist/contract.mjs",
			"require": "./dist/contract.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.mjs",
			"require": "./dist/client.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.mjs",
			"require": "./dist/server.js"
		},
		"./hono": {
			"types": "./dist/hono.d.ts",
			"import": "./dist/hono.mjs",
			"require": "./dist/hono.js"
		},
		"./sveltekit": {
			"types": "./dist/sveltekit.d.ts",
			"import": "./dist/sveltekit.mjs",
			"require": "./dist/sveltekit.js"
		}
	},
    "sideEffects": false,
    "scripts": {
        "lint": "biome check --fix",
        "format": "biome format --write .",
        "check": "tsc --noEmit",
        "check:full": "bun run lint && bun run format && bun run check",
        "build": "tsup",
        "build:full": "bun run check:full && bun run build",
        "test": "bun test",
        "prepublishOnly": "bun run build:full && bun run test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bobosneefdev/zono.git"
    },
    "keywords": [
        "zod",
        "hono",
        "zono"
    ],
    "author": "@bobosneefdev",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/bobosneefdev/zono/issues"
    },
    "dependencies": {
        "hono": "^4.11.3",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.11",
        "@sveltejs/kit": "^2.53.0",
        "@types/bun": "^1.3.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.0.3",
        "ts-essentials": "^10.1.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org"
    },
    "files": [
        "dist",
        "LICENSE"
    ]
}
