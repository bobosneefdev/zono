{
    "name": "@bobosneefdev/zono",
    "version": "9.4.0",
    "type": "module",
    "packageManager": "bun@1.3.5",
    "description": "Easily create contract-first HTTP clients, servers, and gateways using Zod schemas.",
    "homepage": "https://github.com/bobosneefdev/zono#readme",
    "exports": {
        "./client": {
            "types": "./dist/client.d.mts",
            "import": "./dist/client.mjs"
        },
        "./contract": {
            "types": "./dist/contract.d.mts",
            "import": "./dist/contract.mjs"
        },
        "./gateway": {
            "types": "./dist/gateway.d.mts",
            "import": "./dist/gateway.mjs"
        },
        "./middleware": {
            "types": "./dist/middleware.d.mts",
            "import": "./dist/middleware.mjs"
        },
        "./server": {
            "types": "./dist/server.d.mts",
            "import": "./dist/server.mjs"
        },
        "./shared": {
            "types": "./dist/shared.d.mts",
            "import": "./dist/shared.mjs"
        }
    },
    "sideEffects": false,
    "scripts": {
        "lint": "biome check --fix",
        "format": "biome format --write .",
        "check": "tsc --noEmit",
        "check:full": "bun run lint && bun run format && bun run check",
        "build": "tsdown",
        "build:full": "bun run check:full && bun run build",
        "test": "bun test",
        "prepublishOnly": "bun run build:full && bun run test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bobosneefdev/zono.git"
    },
    "keywords": [
        "zod",
        "hono",
        "zono"
    ],
    "author": "@bobosneefdev",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/bobosneefdev/zono/issues"
    },
    "peerDependencies": {
        "hono": "^4.11.3",
        "zod": "^4.3.5"
    },
    "peerDependenciesMeta": {
        "hono": {
            "optional": true
        }
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.11",
        "@types/bun": "^1.3.5",
        "@types/node": "^25.0.3",
        "hono": "^4.11.3",
        "tsdown": "^0.21.0-beta.2",
        "typescript": "^5.9.3",
        "zod": "^4.3.5"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org"
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "dependencies": {
        "superjson": "^2.2.6"
    }
}
